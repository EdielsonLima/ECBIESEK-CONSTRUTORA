#!/bin/bash
set -e
HERMES_HOME="${HERMES_HOME:-/opt/data}"
mkdir -p "$HERMES_HOME"

# Sincroniza skill do image (staging) para o volume
mkdir -p "$HERMES_HOME/skills/productivity"
rm -rf "$HERMES_HOME/skills/productivity/bi-agente"
cp -rf /etc/bi-agente/skills/productivity/bi-agente "$HERMES_HOME/skills/productivity/bi-agente"

# Config + SOUL no HERMES_HOME
cp -f /etc/bi-agente/config.yaml "$HERMES_HOME/config.yaml"
cp -f /etc/bi-agente/SOUL.md "$HERMES_HOME/SOUL.md"

# Instala psycopg2-binary no venv do Hermes usando uv (pip nao existe nessa imagem)
# httpx ja vem instalado na venv oficial
if command -v uv >/dev/null 2>&1 && [ -x /opt/hermes/.venv/bin/python ]; then
  if ! /opt/hermes/.venv/bin/python -c "import psycopg2" 2>/dev/null; then
    echo "[gateway] instalando psycopg2-binary no venv Hermes via uv"
    VIRTUAL_ENV=/opt/hermes/.venv uv pip install psycopg2-binary 2>&1 | tail -3 || echo "[gateway] AVISO: falhou instalar psycopg2-binary"
  else
    echo "[gateway] psycopg2 ja disponivel"
  fi
fi

# Hermes roda como uid 10000 - arquivos root-owned causam Permission denied
chown -R 10000:10000 "$HERMES_HOME" 2>/dev/null || true

exec /opt/hermes/docker/entrypoint.sh gateway "$@"
