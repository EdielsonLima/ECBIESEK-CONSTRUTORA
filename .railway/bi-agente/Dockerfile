FROM nousresearch/hermes-agent:latest
USER root
RUN mkdir -p /etc/bi-agente
# Config e SOUL embutidos como base64 para evitar dependencia de COPY
RUN echo "" | base64 -d > /etc/bi-agente/config.yaml
RUN echo "" | base64 -d > /etc/bi-agente/SOUL.md
RUN printf '#!/bin/bash
set -e
HERMES_HOME="${HERMES_HOME:-/opt/data}"
mkdir -p "$HERMES_HOME"
cp -f /etc/bi-agente/config.yaml "$HERMES_HOME/config.yaml"
cp -f /etc/bi-agente/SOUL.md "$HERMES_HOME/SOUL.md"
chown hermes:hermes "$HERMES_HOME"/{config.yaml,SOUL.md} 2>/dev/null || true
exec /opt/hermes/docker/entrypoint.sh gateway "$@"
' > /usr/local/bin/gateway  && chmod +x /usr/local/bin/gateway
