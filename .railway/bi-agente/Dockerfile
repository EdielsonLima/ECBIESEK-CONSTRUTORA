FROM nousresearch/hermes-agent:latest
USER root
RUN mkdir -p /etc/bi-agente/skills
RUN pip install --no-cache-dir psycopg2-binary httpx
RUN echo "" | base64 -d > /etc/bi-agente/config.yaml
RUN echo "" | base64 -d > /etc/bi-agente/SOUL.md
COPY skills-staging/bi-agente/ /etc/bi-agente/skills/bi-agente/
RUN echo "" | base64 -d > /usr/local/bin/gateway && chmod +x /usr/local/bin/gateway
